{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "isolatedModules": true,
    "noEmit": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["apps/**/*store.ts", "apps/**/*api.ts", "**/*.spec.ts"],
  "exclude": ["node_modules", "tmp"]
}
