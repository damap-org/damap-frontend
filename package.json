{
  "name": "damap-frontend",
  "version": "5.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve damap-frontend",
    "build": "ng build damap-frontend",
    "build:prod": "ng build damap-frontend --configuration=production",
    "build:openshift": "ng build damap-frontend --configuration=openshift",
    "test:spec": "ng test damap-frontend --watch=false",
    "test:spec:watch": "ng test damap-frontend",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:dashboard": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "typecheck:strict": "node tools/check-stricts-ts.mjs tsconfig.strict.json",
    "typecheck:spec": "node tools/check-stricts-ts.mjs tsconfig.strict.spec.json",
    "lint": "npm run typecheck:strict && npm run typecheck:spec && npm run typecheck:e2e && eslint .",
    "format": "npx prettier --write .",
    "ci:install": "npm ci",
    "ci:format": "npx prettier --check .",
    "ci:build": "npm run build",
    "ci:lint": "npm run typecheck:strict && npm run typecheck:spec && npm run typecheck:e2e && eslint .",
    "ci:test:spec": "npm run test:spec",
    "ci:test:e2e": "npm run test:e2e",
    "ci:audit": "npm audit"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "22.0.1",
    "@angular/cdk": "22.0.1",
    "@angular/cli": "22.0.1",
    "@angular/common": "22.0.1",
    "@angular/compiler": "22.0.1",
    "@angular/core": "22.0.1",
    "@angular/forms": "22.0.1",
    "@angular/material": "22.0.1",
    "@angular/material-moment-adapter": "22.0.1",
    "@angular/platform-browser": "22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "22.0.1",
    "@material/material-color-utilities": "^0.3.0",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "angular-oauth2-oidc": "^22.0.0",
    "cors": "2.8.5",
    "deepmerge-ts": "^7.0.3",
    "glob": "10.5.0",
    "js-yaml": "4.1.1",
    "moment": "^2.30.1",
    "ngx-translate-multi-http-loader": "^20.0.0",
    "node-forge": "^1.3.3",
    "rxjs": "^7.8.2",
    "stylus": "^0.63.0",
    "tslib": "^2.8.1",
    "uri-js": "^4.4.1",
    "validator": "13.15.22",
    "vite": "6.4.1",
    "webpack-dev-server": "5.2.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "22.0.1",
    "@angular-devkit/schematics": "22.0.1",
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.1",
    "@angular/compiler-cli": "22.0.1",
    "@angular/language-service": "22.0.1",
    "@playwright/test": "^1.61.1",
    "@schematics/angular": "^22.0.1",
    "@types/node": "^22.19.21",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@typescript-eslint/utils": "^8.61.1",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "9.1.0",
    "glob": "10.5.0",
    "jsdom": "^28.1.0",
    "postcss": "8.4.38",
    "postcss-import": "16.1.0",
    "postcss-preset-env": "9.5.14",
    "postcss-url": "10.1.3",
    "prettier": "3.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "6.4.1",
    "vitest": "^4.1.9",
    "webpack-dev-server": "5.2.1"
  },
  "overrides": {
    "tar": "^7.5.7",
    "webpack": "^5.104.1",
    "diff": "^4.0.3"
  }
}
