{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "damap-frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "apps/damap-shell",
      "sourceRoot": "apps/damap-shell/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/damap-frontend"
            },
            "index": "apps/damap-shell/src/index.html",
            "polyfills": ["apps/damap-shell/src/polyfills.ts"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "apps/damap-shell/src/favicon.ico",
              "apps/damap-shell/src/assets",
              {
                "glob": "**/*",
                "input": "apps/damap-core/src/assets/",
                "output": "./assets/damap/"
              }
            ],
            "styles": [
              "apps/damap-shell/src/styles.scss",
              "apps/damap-core/src/assets/styles.scss"
            ],
            "scripts": [],
            "allowedCommonJsDependencies": ["validator", "moment"],
            "browser": "apps/damap-shell/src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "12mb",
                  "maximumError": "15mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "8kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "apps/damap-shell/src/environments/environment.ts",
                  "with": "apps/damap-shell/src/environments/environment.prod.ts"
                },
                {
                  "replace": "apps/damap-core/src/app/constants.ts",
                  "with": "apps/damap-core/src/app/constants.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            },
            "openshift": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "12mb",
                  "maximumError": "15mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "6kb",
                  "maximumError": "8kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "apps/damap-shell/src/environments/environment.ts",
                  "with": "apps/damap-shell/src/environments/environment.openshift.ts"
                }
              ],
              "outputHashing": "all"
            },
            "testing": {
              "aot": false,
              "optimization": false,
              "extractLicenses": false,
              "polyfills": [],
              "assets": ["apps/damap-shell/src/favicon.ico", "apps/damap-shell/src/assets"]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "damap-frontend:build:production"
            },
            "development": {
              "buildTarget": "damap-frontend:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "damap-frontend:build"
          }
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "tsconfig.spec.json",
            "buildTarget": "damap-frontend:build:testing",
            "runnerConfig": "vitest.config.ts",
            "include": ["**/*.spec.ts", "../../damap-core/src/**/*.spec.ts"]
          }
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "apps/damap-shell/src/**/*.ts",
              "apps/damap-shell/src/**/*.html",
              "apps/damap-core/src/**/*.ts",
              "apps/damap-core/src/**/*.html"
            ]
          }
        }
      }
    }
  },
  "cli": {
    "schematicCollections": ["@angular-eslint/schematics"],
    "analytics": false
  },
  "schematics": {
    "@angular-eslint/schematics:application": {
      "setParserOptionsProject": true
    },
    "@angular-eslint/schematics:library": {
      "setParserOptionsProject": true
    },
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
