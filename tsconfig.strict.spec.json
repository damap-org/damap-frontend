{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "isolatedModules": true,
    "noEmit": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["vitest"]
  },
  "include": ["apps/**/*.spec.ts"],
  "exclude": ["node_modules", "tmp"]
}
